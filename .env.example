# SwiftNext environment configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and should NEVER be committed.
# ----------------------------------------------------------------------

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info

# Database driver: "sqlite" | "postgres"
DB_DRIVER=sqlite
SQLITE_PATH=swiftnext.db

# Postgres (only used when DB_DRIVER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=swiftnext

# Client
SWIFTNEXT_API_BASE_URL=http://localhost:8080
